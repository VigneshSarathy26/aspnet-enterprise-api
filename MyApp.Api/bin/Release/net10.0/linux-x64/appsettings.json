{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=billing_telemetry;Username=billing_user;Password=billing_pass",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Authority": "https://your-identity-provider.auth0.com/",
    "Audience":  "cloud-billing-telemetry-api"
  },
  "RateLimiting": {
    "IngestPermitLimit": 500,
    "QueryPermitLimit":  200
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default":   "Information",
      "Override": {
        "Microsoft":                            "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System":                               "Warning"
      }
    }
  }
}
