{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "DatabaseProvider": "Oracle",
  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=billing_telemetry_dev;User Id=sa;Password=YourStrong@Password;TrustServerCertificate=True;",
    "Oracle": "Data Source=localhost:1521/FREEPDB1;User Id=system;Password=YourStrong@Password;",
    "Postgres": "Host=localhost;Port=5432;Database=billing_telemetry_dev;Username=billing_user;Password=billing_pass",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Authority": "https://dev-identity.example.com/",
    "Audience":  "cloud-billing-telemetry-api"
  },
  "RateLimiting": {
    "IngestPermitLimit": 10000,
    "QueryPermitLimit":  5000
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  }
}
