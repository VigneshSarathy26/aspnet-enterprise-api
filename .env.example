# Environment Variables — copy to .env and fill in your values
# Never commit the actual .env file

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=billing_telemetry
POSTGRES_USER=billing_user
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_CONNECTION=localhost:6379,abortConnect=false

# JWT
JWT_AUTHORITY=https://your-idp.auth0.com/
JWT_AUDIENCE=cloud-billing-telemetry-api

# OpenTelemetry / Jaeger
OTEL_ENDPOINT=http://localhost:4317

# Rate Limiting
RATE_LIMIT_INGEST=500
RATE_LIMIT_QUERY=200
